{
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "textlint": "textlint docs/*.md README.md",
    "textlint:fix": "textlint --fix docs/*.md README.md",
    "markdownlint": "markdownlint-cli2 docs/*.md README.md",
    "markdownlint:fix": "markdownlint-cli2 --fix docs/*.md README.md",
    "prettier:check": "prettier --check \"**/*.{yml,yaml,json}\"",
    "prettier:fix": "prettier --write \"**/*.{yml,yaml,json}\""
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.17",
    "prettier": "^3",
    "textlint": "^15",
    "textlint-rule-preset-ja-spacing": "^2",
    "textlint-rule-preset-ja-technical-writing": "^10"
  }
}
